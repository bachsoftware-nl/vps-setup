cat > "$FUNC_DIR/kill-zombies.fish" << 'FUNC'
function kill-zombies --description "Kill parent processes van zombie processen"
    set zombie_info (ps -eo pid,ppid,stat,comm | awk '$3 ~ /^Z/ {print $1, $2, $4}')
    if test -z "$zombie_info"
        echo "No zombie processes found."
        return 0
    end
    set zombie_pids (ps -eo pid,stat | awk '$2 ~ /^Z/ {print $1}')
    set parent_pids (ps -eo pid,ppid,stat | awk '$3 ~ /^Z/ {print $2}' | sort -u)
    set_color brred
    echo "Found "(count $zombie_pids)" zombie process(es):"
    set_color normal
    ps -eo pid,ppid,stat,comm | awk 'NR==1 || $3 ~ /^Z/'
    echo ""
    set_color bryellow
    echo "Signaling parent process(es) to reap zombies..."
    set_color normal
    for ppid in $parent_pids
        if test "$ppid" = "1"
            echo "  PID 1 (init/systemd) is parent — zombie will be reaped automatically."
            continue
        end
        set pname (ps -p $ppid -o comm= 2>/dev/null; or echo "unknown")
        if kill -SIGCHLD $ppid 2>/dev/null
            set_color green
            echo "  Sent SIGCHLD to parent PID $ppid ($pname)"
            set_color normal
        else
            set_color brred
            echo "  Could not signal PID $ppid ($pname) — try running with sudo"
            set_color normal
        end
    end
    sleep 0.5
    set remaining (ps -eo stat | awk '$1 ~ /^Z/' | wc -l | string trim)
    if test "$remaining" = "0"
        set_color brgreen
        echo ""
        echo "All zombies reaped."
        set_color normal
    else
        set_color bryellow
        echo ""
        echo "$remaining zombie(s) still remain. Their parents may need to be killed directly:"
        set_color normal
        set stubborn_parents (ps -eo pid,ppid,stat | awk '$3 ~ /^Z/ {print $2}' | sort -u)
        for ppid in $stubborn_parents
            if test "$ppid" = "1"
                continue
            end
            set pname (ps -p $ppid -o comm= 2>/dev/null; or echo "unknown")
            echo "  kill $ppid  # $pname"
        end
    end
end
FUNC

cat > "$FUNC_DIR/motd.fish" << 'FUNC'
