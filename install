cat > "$FUNC_DIR/screenshot.fish" << 'FUNC'
function screenshot --description "Maak een headless screenshot van een project of URL"
    if test (count $argv) -lt 1
        echo "Gebruik: screenshot <project-of-url> [breedte] [hoogte]"
        echo "  screenshot mijnapp          → https://mijnapp.jouwdomein.nl"
        echo "  screenshot https://example.com"
        echo "  screenshot mijnapp 1920 1080"
        return 1
    end

    set input $argv[1]
    set width 1280
    set height 800
    if test (count $argv) -ge 3
        set width $argv[2]
        set height $argv[3]
    end

    if string match -q "http*" $input
        set url $input
        set name (echo $input | string replace -ra 'https?://' '' | string replace -ra '[^a-z0-9]' '-' | string lower)
    else
        set domain_file $HOME/traefik/.domain
        if test -f $domain_file
            set domain (cat $domain_file | string trim)
        else
            read -P "Basis domein: " domain
        end
        set url "https://$input.$domain"
        set name $input
    end

    set outdir $HOME/screenshots
    mkdir -p $outdir
    set outfile "$outdir/screenshot-$name-"(date +%s)".png"

    echo "📸 Screenshot van $url..."

    playwright screenshot \
        --browser chromium \
        --viewport-size "$width,$height" \
        --wait-for-timeout 2000 \
        $url $outfile

    if test $status -eq 0
        set_color brgreen
        echo "✓ Opgeslagen: $outfile"
        set_color normal
        echo ""
        echo "Gebruik in Claude Code:"
        echo "  Read het bestand: $outfile"
    else
        set_color brred
        echo "Screenshot mislukt."
        set_color normal
        return 1
    end
end
FUNC

cat > "$FUNC_DIR/new-project.fish" << 'FUNC'
function new-project --description "Maak een nieuw project aan met Traefik docker-compose"
    if test (count $argv) -lt 1
        echo "Gebruik: new-project <naam> [poort]"
        echo "  naam   projectnaam (wordt subdomain: naam.jouwdomein.nl)"
        echo "  poort  interne containerpoort (standaard: 3000)"
        return 1
    end

    set project_name $argv[1]
    set port 3000
    if test (count $argv) -ge 2
        set port $argv[2]
    end

    set domain_file $HOME/traefik/.domain
    if test -f $domain_file
        set base_domain (cat $domain_file | string trim)
    else
        read -P "Basis domein (bijv. jouwdomein.nl): " base_domain
    end

    set project_dir $HOME/projects/$project_name
    if test -d $project_dir
        set_color brred
        echo "Map $project_dir bestaat al."
        set_color normal
        return 1
    end

    mkdir -p $project_dir
    cat > $project_dir/docker-compose.yml << COMPOSE
services:
  $project_name:
    image: your-image:latest
    # build:
    #   context: .
    #   dockerfile: Dockerfile
    restart: unless-stopped
    networks:
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.$project_name.rule=Host(\`$project_name.$base_domain\`)"
      - "traefik.http.routers.$project_name.entrypoints=websecure"
      - "traefik.http.routers.$project_name.tls.certresolver=letsencrypt"
      - "traefik.http.services.$project_name.loadbalancer.server.port=$port"

networks:
  proxy:
    external: true
COMPOSE

    cat > $project_dir/.env << ENV
# $project_name omgevingsvariabelen
ENV

    echo ""
    set_color brgreen --bold
    echo "  Project '$project_name' aangemaakt!"
    set_color normal
    echo ""
    set_color brblue
    echo "  Map:    $project_dir"
    echo "  URL:    https://$project_name.$base_domain"
    echo "  Poort:  $port (intern)"
    set_color normal
    echo ""
    echo "  Volgende stappen:"
    echo "  1. Pas docker-compose.yml aan (image of build sectie)"
    echo "  2. cd $project_dir"
    echo "  3. docker compose up -d"
    echo ""
end
FUNC

cat > "$FUNC_DIR/traefik-status.fish" << 'FUNC'
function traefik-status --description "Toon Traefik status en actieve routers"
    echo ""
    set_color brblue --bold
    echo "  Traefik status"
    set_color brblack
    echo "  ─────────────────────────────────────────────"
    set_color normal

    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^traefik$'
        set_color brgreen
        echo "  Traefik draait"
        set_color normal
    else
        set_color brred
        echo "  Traefik draait NIET"
        set_color normal
        echo ""
        return 1
    end

    set domain_file $HOME/traefik/.domain
    if test -f $domain_file
        set base_domain (cat $domain_file | string trim)
        set_color brblack
        echo "  Domein: $base_domain"
        set_color normal
    end

    echo ""
    set_color brblue --bold
    echo "  Containers op proxy netwerk"
    set_color brblack
    echo "  ─────────────────────────────────────────────"
    set_color normal

    set containers (docker network inspect proxy --format '{{range .Containers}}{{.Name}} {{end}}' 2>/dev/null | string split ' ' | string trim | grep -v '^$')
    if test (count $containers) -eq 0
        set_color brblack
        echo "  Geen containers gevonden op proxy netwerk."
        set_color normal
    else
        for c in $containers
            set status (docker inspect $c --format '{{.State.Status}}' 2>/dev/null)
            if test "$status" = "running"
                set_color brgreen; printf "  ● "; set_color normal
            else
                set_color brred; printf "  ○ "; set_color normal
            end
            echo $c
        end
    end
    echo ""
end
FUNC

cat > "$FUNC_DIR/_cmd_picker.fish" << 'FUNC'
function _cmd_picker --description "Interactieve command-kiezer (Alt+K)"
    set -l icons    "🚀" "🤖" "👾" "📺" "💀" "📋" "🔀" "🔄" "🧟" "🆕" "🔌" "📸"
    set -l names    oc cc ai tc tk tl t server-update kill-zombies new-project traefik-status screenshot
    set -l descs \
        "Open/koppel een tmux sessie + opencode" \
        "Open/koppel een tmux sessie + claude code" \
        "Bekijk draaiende AI-instanties (opencode + claude)" \
        "Maak een nieuwe tmux sessie" \
        "Slachtoffer van de dag: kill een tmux sessie" \
        "Bekijk alle tmux sessies (met agent-iconen ⚡✦)" \
        "Spring naar een sessie op naam of nummer [tab!]" \
        "Update alle Ubuntu-pakketten" \
        "Jaag zombie-processen naar het hiernamaals" \
        "Nieuw project aanmaken met Traefik docker-compose" \
        "Toon Traefik status en actieve containers" \
        "Headless screenshot van project of URL"

    set -l lines
    for i in (seq (count $names))
        set -a lines (printf '%s  %-16s  %s' $icons[$i] $names[$i] $descs[$i])
    end

    set -l selected (printf '%s\n' $lines \
        | fzf \
            --height=~50% \
            --reverse \
            --no-info \
            --prompt='  ▸ ' \
            --header='  Command kiezen — Enter voegt in, Esc annuleert' \
            --color='header:italic:bright-black,prompt:bright-cyan,pointer:bright-cyan')

    if test -z "$selected"
        commandline -f repaint
        return
    end

    set -l cmd (echo $selected | string replace -r '^.\S*\s+(\S+).*' '$1')
    if test -n "$cmd"
        commandline -r $cmd
    end
    commandline -f repaint
end
FUNC

cat > "$FUNC_DIR/fish_user_key_bindings.fish" << 'FUNC'
function fish_user_key_bindings
    bind \ek _cmd_picker
end
FUNC

# ── 12. MOTD scripts ────────────────────────────────────────────────────────────
info "MOTD scripts schrijven..."

cat > /etc/update-motd.d/55-ssh-connections << 'MOTD'
#!/bin/sh
CONNECTIONS=$(who | awk '$5 ~ /^\(/ && $5 !~ /tmux|screen/ {print}')
if [ -n "$CONNECTIONS" ]; then
    printf "\n SSH-verbindingen:\n"
    printf "    %-12s %-8s %-20s %s\n" "Gebruiker" "Terminal" "Tijdstip" "IP-adres"
    printf "    %-12s %-8s %-20s %s\n" "------------" "--------" "--------------------" "--------"
    who | awk '$5 ~ /^\(/ && $5 !~ /tmux|screen/ {
        user = $1; tty = $2; dt = $3 " " $4; ip = $5
        gsub(/[()]/, "", ip)
        printf "    %-12s %-8s %-20s %s\n", user, tty, dt, ip
    }'
    printf "\n"
fi
MOTD

cat > /etc/update-motd.d/60-ai-instances << 'MOTD'
#!/bin/sh
#
#    60-ai-instances - toon draaiende OpenCode en Claude Code instanties
#

OC=$(ps -eo pid,lstart,tty,cmd --no-headers | awk '$NF == "opencode"')
CC=$(ps -eo pid,lstart,tty,cmd --no-headers | awk '$NF == "claude"')

if [ -n "$OC" ] || [ -n "$CC" ]; then
    printf "\n AI-instanties:\n"
    printf "    %-8s %-24s %-12s %s\n" "PID" "Gestart om" "Terminal" "Kill commando"
    printf "    %-8s %-24s %-12s %s\n" "--------" "------------------------" "------------" "-------------"

    ps -eo pid,lstart,tty,cmd --no-headers | awk '$8 == "opencode" {
        pid = $1
        started = $2 " " $3 " " $4 " " $5 " " $6
        tty_disp = ($7 == "?") ? "-" : "/dev/" $7
        printf " ⚪ %-8s %-24s %-12s kill %s\n", pid, started, tty_disp, pid
    }'
    ps -eo pid,lstart,tty,cmd --no-headers | awk '$8 == "claude" {
        pid = $1
        started = $2 " " $3 " " $4 " " $5 " " $6
        tty_disp = ($7 == "?") ? "-" : "/dev/" $7
        printf " 🟠 %-8s %-24s %-12s kill %s\n", pid, started, tty_disp, pid
    }'
    printf "\n"
fi
MOTD

chmod +x /etc/update-motd.d/55-ssh-connections
chmod +x /etc/update-motd.d/60-ai-instances

# ── 13. Traefik wizard ──────────────────────────────────────────────────────────
TRAEFIK_DIR="$DEPLOY_HOME/traefik"
TRAEFIK_SKIP=false

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}  Traefik reverse proxy instellen${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo "  Traefik is de centrale reverse proxy voor al je projecten."
echo "  Elk nieuw project krijgt automatisch HTTPS via Let's Encrypt."
echo ""
read -rp "  Traefik instellen? [J/n] " _traefik_yn
_traefik_yn="${_traefik_yn:-J}"

if [[ "$_traefik_yn" =~ ^[nN] ]]; then
    warn "Traefik overgeslagen. Draai later: sudo bash <(curl ...) of stel handmatig in."
    TRAEFIK_SKIP=true
fi

if [[ "$TRAEFIK_SKIP" == false ]]; then
    # Domein ophalen
    echo ""
    read -rp "  Jouw domein (bijv. jouwdomein.nl): " TRAEFIK_DOMAIN
    TRAEFIK_DOMAIN="${TRAEFIK_DOMAIN:-jouwdomein.nl}"

    read -rp "  E-mail voor Let's Encrypt: " LETSENCRYPT_EMAIL
    LETSENCRYPT_EMAIL="${LETSENCRYPT_EMAIL:-admin@${TRAEFIK_DOMAIN}}"

    # Server IP ophalen
    SERVER_IP=$(curl -fsSL https://api.ipify.org 2>/dev/null || hostname -I | awk '{print $1}')

    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  DNS instellen — doe dit nu in je DNS-beheer${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  Voeg deze DNS-records toe bij jouw domeinbeheerder:"
    echo ""
    printf "  %-12s  %-30s  %-5s  %s\n" "Type" "Naam" "TTL" "Waarde"
    printf "  %-12s  %-30s  %-5s  %s\n" "────────────" "──────────────────────────────" "─────" "───────────────"
    printf "  %-12s  %-30s  %-5s  %s\n" "A" "${TRAEFIK_DOMAIN}" "300" "${SERVER_IP}"
    printf "  %-12s  %-30s  %-5s  %s\n" "A (wildcard)" "*.${TRAEFIK_DOMAIN}" "300" "${SERVER_IP}"
    echo ""
    echo "  Het wildcard record (*.${TRAEFIK_DOMAIN}) zorgt dat elk"
    echo "  nieuw project direct bereikbaar is via project.${TRAEFIK_DOMAIN}"
    echo "  zonder extra DNS-wijzigingen."
    echo ""
    echo "  Traefik dashboard: https://traefik.${TRAEFIK_DOMAIN}"
    echo ""
    read -rp "  DNS ingesteld en klaar om verder te gaan? [J/n] " _dns_yn
    _dns_yn="${_dns_yn:-J}"

    if [[ "$_dns_yn" =~ ^[nN] ]]; then
        warn "Traefik configuratie aangemaakt maar niet gestart."
        warn "Start later met: cd ~/traefik && docker compose up -d"
        TRAEFIK_START=false
    else
        TRAEFIK_START=true
    fi

    # Docker proxy netwerk aanmaken
    if ! docker network ls --format '{{.Name}}' | grep -q '^proxy$'; then
        docker network create proxy
        success "Docker netwerk 'proxy' aangemaakt"
    else
        success "Docker netwerk 'proxy' al aanwezig"
    fi

    # Traefik directory en bestanden aanmaken
    mkdir -p "$TRAEFIK_DIR/dynamic"
    touch "$TRAEFIK_DIR/acme.json"
    chmod 600 "$TRAEFIK_DIR/acme.json"

    # Traefik dashboard wachtwoord genereren (basic auth)
    TRAEFIK_PASS=$(tr -dc 'A-Za-z0-9' </dev/urandom | head -c 20)
    TRAEFIK_HASH=$(docker run --rm httpd:2.4-alpine htpasswd -nbB admin "$TRAEFIK_PASS" 2>/dev/null \
        | sed 's/\$/\$\$/g' || echo "admin:$$apr1$$changeme$$")

    # docker-compose.yml schrijven
    cat > "$TRAEFIK_DIR/docker-compose.yml" << TRAEFIK_COMPOSE
services:
  traefik:
    image: traefik:v3.2
    container_name: traefik
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    networks:
      - proxy
    ports:
      - "80:80"
      - "443:443"
    environment:
      - TRAEFIK_CERTIFICATESRESOLVERS_letsencrypt_ACME_EMAIL=${LETSENCRYPT_EMAIL}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./acme.json:/acme.json
      - ./dynamic:/etc/traefik/dynamic:ro
    command:
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
      - --providers.docker.network=proxy
      - --providers.file.directory=/etc/traefik/dynamic
      - --providers.file.watch=true
      - --entrypoints.web.address=:80
      - --entrypoints.websecure.address=:443
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
      - --entrypoints.web.http.redirections.entrypoint.permanent=true
      - --certificatesresolvers.letsencrypt.acme.httpchallenge=true
      - --certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web
      - --certificatesresolvers.letsencrypt.acme.storage=/acme.json
      - --api.dashboard=true
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.traefik-dashboard.rule=Host(\`traefik.${TRAEFIK_DOMAIN}\`)"
      - "traefik.http.routers.traefik-dashboard.entrypoints=websecure"
      - "traefik.http.routers.traefik-dashboard.tls.certresolver=letsencrypt"
      - "traefik.http.routers.traefik-dashboard.service=api@internal"
      - "traefik.http.routers.traefik-dashboard.middlewares=traefik-auth"
      - "traefik.http.middlewares.traefik-auth.basicauth.users=${TRAEFIK_HASH}"

networks:
  proxy:
    external: true
TRAEFIK_COMPOSE

    # .env opslaan
    cat > "$TRAEFIK_DIR/.env" << TRAEFIK_ENV
TRAEFIK_DOMAIN=${TRAEFIK_DOMAIN}
LETSENCRYPT_EMAIL=${LETSENCRYPT_EMAIL}
TRAEFIK_ENV

    # Domein opslaan voor fish functies
    echo "$TRAEFIK_DOMAIN" > "$TRAEFIK_DIR/.domain"

    chown -R "$DEPLOY_USER:$DEPLOY_USER" "$TRAEFIK_DIR"

    success "Traefik configuratie aangemaakt in ~/traefik/"

    # Traefik starten als DNS klaar is
    if [[ "$TRAEFIK_START" == true ]]; then
        info "Traefik starten..."
        docker compose -f "$TRAEFIK_DIR/docker-compose.yml" up -d
        success "Traefik draait!"
        echo ""
        echo -e "  Dashboard: ${CYAN}https://traefik.${TRAEFIK_DOMAIN}${NC}"
        echo -e "  Gebruiker: ${CYAN}admin${NC}"
        echo -e "  Wachtwoord: ${YELLOW}${TRAEFIK_PASS}${NC}"
        echo ""
        warn "Sla het wachtwoord op! Het wordt niet opnieuw getoond."
        echo "  (Staat ook in: ~/traefik/.env)"
        # Wachtwoord opslaan in .env
        echo "TRAEFIK_DASHBOARD_PASSWORD=${TRAEFIK_PASS}" >> "$TRAEFIK_DIR/.env"
    fi
fi

# ── 14. Eigenaarschap corrigeren ─────────────────────────────────────────────────
chown -R "$DEPLOY_USER:$DEPLOY_USER" "$DEPLOY_HOME/.config"
[[ -d "$DEPLOY_HOME/.opencode" ]] && chown -R "$DEPLOY_USER:$DEPLOY_USER" "$DEPLOY_HOME/.opencode"

