echo ""
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}  Setup klaar!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo "  Volgende stappen:"
echo "  1. Log in als $DEPLOY_USER:       su - $DEPLOY_USER"
echo "  2. Authenticeer Claude:            claude"
echo "  3. Authenticeer opencode:          opencode (run /connect → GitHub Copilot)"
echo "  4. Start Claude in tmux:           cc mijn-project"
echo "  5. Start opencode in tmux:         oc mijn-project"
if [[ "$TRAEFIK_SKIP" == false ]]; then
echo "  4. Nieuw project starten:          new-project mijnapp"
fi
echo ""
